# ============================================
# 信仰答题自动化工具 - 环境配置模板
# ============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改下面的配置项为你的实际值
# 3. 不要将 .env 文件提交到 Git（已加入 .gitignore）
# ============================================

# ---------- 账号信息（必填）----------
# 登录手机号
PHONE_NUMBER=你的手机号

# 登录密码
PASSWORD=你的密码

# ---------- 网站配置（必填）----------
# 登录页面URL
WEBSITE_URL=https://ms.tqzyxy.com/passport/mlogin?refer=https%3A%2F%2Fms.tqzyxy.com%2Fappswh%2Ffront%2Fquizapp%2FcustomHome%3FcategoryId%3D89B64658CF2FA01E

# 答题页面URL（包含 categoryId, questionConfigId 等参数）
QUESTION_URL=https://ms.tqzyxy.com/appswh/front/quizapp/practice?categoryId=20003&categoryIdEnc=89B64658CF2FA01E&title=%E4%BF%A1%E4%BB%B0%E7%9F%A5%E8%AF%86%E6%8C%91%E6%88%98&questionConfigId=21993&answerTimeLimit=2000&questionLimit=10

# ---------- 答题配置 ----------
# 每轮答题数量限制（默认10题）
QUESTIONLIMIT=10

# 最大运行轮数（默认1轮）
MAX_ROUNDS=1

# 每题答题间隔时间（毫秒，默认500ms）
ANSWER_INTERVAL=500

# 答题时限（秒，默认20秒）
ANSWERTIMELIMIT=20

# 目标分数（默认180分）（未实现）
END_SCORE=180

# ---------- 浏览器配置 ----------
# 是否无头模式运行（true=后台运行不显示浏览器，false=显示浏览器窗口）
HEADLESS=false
